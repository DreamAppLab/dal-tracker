rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthorizedUser() {
      return request.auth != null && request.auth.uid == 'aEbUJSYaP7aXnYtnSk3A5I4iLp72';
    }

    match /{document=**} {
      allow read, write: if isAuthorizedUser();
    }
  }
}
